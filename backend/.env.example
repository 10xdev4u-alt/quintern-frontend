# ==============================
# CORE APP CONFIG
# ==============================
NODE_ENV=development
PORT=5000

# ==============================
# AUTH
# ==============================
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d
API_KEY=change-me

# ==============================
# DATABASE (POSTGRES)
# ==============================
# Production: use a real PostgreSQL connection string (Neon, Render, etc.)
DATABASE_URL=postgresql://user:password@host/db

# Dev mode — no Docker, no PG server! Uses PostgreSQL-in-WASM via @electric-sql/pglite
# Set this to a directory path to enable embedded PGlite instead of PostgreSQL.
# Then run: PGLITE_DB_DIR=./pglite-data npm run migrate && npm run dev
# All PostgreSQL features work (WITH RECURSIVE, ENUMs, JSONB, ILIKE, etc.)
# PGLITE_DB_DIR=./pglite-data

# ==============================
# GOOGLE AUTH
# ==============================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==============================
# PHONE OTP (FAST2SMS)
# ==============================
FAST2SMS_API_KEY=your-fast2sms-key

# ==============================
# AI SERVICES
# ==============================
FASTAPI_URL=http://localhost:8000/api/chat
AI_TIMEOUT=25000
GROQ_API_KEY=your-groq-key
OPENAI_API_KEY=your-openai-key
GEMINI_API_KEY=your-gemini-key
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
HUGGINGFACE_TOKEN=your-hf-token

# ==============================
# EMAIL (Resend)
# ==============================
# Resend is the email provider. Free tier: 3,000 emails/month, 100 emails/day.
# Get a free API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Quintern <noreply@quintern.com>
EMAIL_RETRY_MAX=3
EMAIL_RATE_LIMIT=5
EMAIL_RATE_WINDOW=60000
APP_URL=http://localhost:5173

# ==============================
# REDIS (UPSTASH)
# ==============================
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
